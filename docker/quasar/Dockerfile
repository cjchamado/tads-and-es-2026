FROM node:22-alpine

LABEL maintainer="Claudinei José Machado"

###############################################################################
# Dependências do Sistema
###############################################################################

RUN apk add --no-cache \
    bash \
    git

###############################################################################
# Quasar CLI
###############################################################################

RUN npm install -g @quasar/cli

###############################################################################
# Diretório de Trabalho
###############################################################################

WORKDIR /app

###############################################################################
# Porta do Vite
###############################################################################

EXPOSE 9000

###############################################################################
# Comando padrão
###############################################################################

# CMD ["sh"]
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
